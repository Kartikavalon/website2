{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "zenoway.co.in" }],
      "destination": "https://www.zenoway.co.in/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.zenoway.co.in" }],
      "destination": "https://www.zenoway.co.in/$1",
      "permanent": true
    }
  ]
}